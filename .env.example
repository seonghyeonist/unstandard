# ============================================================
# Unstandard 환경변수 예시 (.env.example)
# 복사: cp .env.example .env.local   (프론트엔드)
#       cp .env.example .env         (docker compose 백엔드 스택)
# 실제 비밀값은 절대 커밋하지 마세요.
# ============================================================

# --- 프론트엔드 (Next.js) ---
# 기본값은 "비움" = standalone mock 모드입니다.
# 비워두면 답변 잠금해제 플로우가 로컬 mockVerdict(lib/api/answers.ts)를 사용합니다.
# 실제 depth-service에 붙이려면 docker compose 스택을 먼저 띄운 뒤
# 아래 값을 http://localhost:8000 으로 설정하세요.
# (스택 없이 값을 채우면 fetch 실패로 verdict가 ERROR로 표시됩니다.)
NEXT_PUBLIC_API_BASE_URL=

# --- Supabase alpha adapter (server-only preferred) ---
# When both are set, mock auth is disabled and middleware protects /app routes.
# Prefer UNSTANDARD_* (server-only on Vercel). Legacy NEXT_PUBLIC_* below is temporary fallback only.
UNSTANDARD_SUPABASE_URL=
UNSTANDARD_SUPABASE_PUBLISHABLE_KEY=
# Optional OAuth provider for staging login button (github, google, apple, discord)
UNSTANDARD_SUPABASE_OAUTH_PROVIDER=
# Optional explicit redirect origin for magic link / OAuth (defaults to request host)
UNSTANDARD_APP_URL=

# LEGACY (temporary fallback — do not use for new code)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to browser or NEXT_PUBLIC_*
# Not required for user-scoped auth/login/reports paths in this PR.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — signs unlock/mock session cookies (required in production)
AUTH_COOKIE_SECRET=

# --- Reports persistence (server-side gate) ---
# Default / unset = disabled (503 fail-closed on POST /api/reports).
# Supabase env alone does NOT enable reports DB persistence.
REPORTS_PERSISTENCE_ADAPTER=disabled
# REPORTS_PERSISTENCE_ADAPTER=supabase-alpha

# 아래 호스트명(postgres/tei/qwen-review)은 docker compose 네트워크 기준입니다.
# 컨테이너 밖에서 직접 실행할 때는 localhost로 바꾸세요.
POSTGRES_DB=unstandard
POSTGRES_USER=unstandard
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://unstandard:localdev@postgres:5432/unstandard
TEI_BASE_URL=http://tei:8080
QWEN_REVIEW_URL=http://qwen-review:8001/internal/qwen/review
