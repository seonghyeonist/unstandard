# ============================================================
# Unstandard environment contract (.env.example)
# Copy: cp .env.example .env.local
# Never commit real secrets.
# ============================================================

# --- Frontend ---
# Empty = standalone mock depth verdict (lib/api/answers.ts)
NEXT_PUBLIC_API_BASE_URL=
# Optional client hint only — never a secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Runtime mode ---
# local dev mock: UNSTANDARD_RUNTIME_MODE=mock
# staging/preview/production: UNSTANDARD_RUNTIME_MODE=database
UNSTANDARD_RUNTIME_MODE=mock
DATABASE_ENV=local

# --- Database (server-only) ---
DATABASE_URL=postgresql://unstandard:localdev@localhost:5432/unstandard
TEST_DATABASE_URL=

# --- Better Auth (server-only) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
UNSTANDARD_APP_URL=http://localhost:3000

# --- Invite hashing pepper (server-only) ---
# Falls back to BETTER_AUTH_SECRET when unset
ALPHA_INVITE_PEPPER=

# --- Unlock/mock cookie signing (server-only) ---
AUTH_COOKIE_SECRET=

# --- Integration / migration safety ---
UNSTANDARD_CONFIRM_DB_MIGRATE=
UNSTANDARD_CONFIRM_DESTRUCTIVE_TEST=
UNSTANDARD_READINESS_SMOKE_PASS=

# --- Preview adversarial smoke (names only in docs) ---
SMOKE_BASE_URL=
SMOKE_USER_A_EMAIL=
SMOKE_USER_A_PASSWORD=
SMOKE_USER_B_EMAIL=
SMOKE_USER_B_PASSWORD=

# --- Docker compose depth stack (optional) ---
POSTGRES_DB=unstandard
POSTGRES_USER=unstandard
POSTGRES_PASSWORD=localdev
TEI_BASE_URL=http://tei:8080
QWEN_REVIEW_URL=http://qwen-review:8001/internal/qwen/review
