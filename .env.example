# ============================================================
# Unstandard environment contract (.env.example)
# Name-only operator manifest. Never commit real secrets.
# Copy: cp .env.example .env.local
# ============================================================

# --- Frontend ---
# Optional client hint only — never a secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
# There is intentionally no public/client env var that can select or
# credential a remote Depth service. The live app always scores answers with
# the deterministic mock-local-heuristic-v0.0 (see docs/LOCAL_AI_POC_STATUS.md).

# --- Runtime mode ---
# local dev mock: UNSTANDARD_RUNTIME_MODE=mock
# staging/preview/production: UNSTANDARD_RUNTIME_MODE=database
UNSTANDARD_RUNTIME_MODE=mock
DATABASE_ENV=local

# --- Database (server-only) ---
# Preview/runtime migrate+seed: DATABASE_URL + DATABASE_ENV=staging
# Disposable integration only: TEST_DATABASE_URL + DATABASE_ENV=test
# Do not reuse one database for both purposes.
DATABASE_URL=postgresql://unstandard:localdev@localhost:5432/unstandard
TEST_DATABASE_URL=

# --- Better Auth (server-only) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
UNSTANDARD_APP_URL=http://localhost:3000

# --- Invite hashing pepper (server-only) ---
# Optional in code (falls back to BETTER_AUTH_SECRET); prefer explicit Preview-only value
ALPHA_INVITE_PEPPER=

# --- Unlock/mock cookie signing (server-only) ---
AUTH_COOKIE_SECRET=

# --- Integration / migration safety ---
# Preview migrate: UNSTANDARD_CONFIRM_DB_MIGRATE=yes
# Disposable integration: UNSTANDARD_CONFIRM_DESTRUCTIVE_TEST=yes
UNSTANDARD_CONFIRM_DB_MIGRATE=
UNSTANDARD_CONFIRM_DESTRUCTIVE_TEST=

# Optional (not default): allow overwriting a PASS proof artifact from a different gitSha
UNSTANDARD_PROOF_OVERWRITE_DIFFERENT_SHA=

# DEPRECATED / UNUSED_CONFIRMED — not read by active scripts or lib.
# Kept as an empty placeholder so operators do not invent a false gate.
# Use machine artifacts + readiness:alpha instead.
UNSTANDARD_READINESS_SMOKE_PASS=

# --- Disposable integration evidence paths (names only) ---
UNSTANDARD_INTEGRATION_EVIDENCE_OUT=

# --- Authenticated Preview smoke (names only) ---
SMOKE_BASE_URL=
SMOKE_VERCEL_PROTECTION_BYPASS=
SMOKE_USER_A_EMAIL=
SMOKE_USER_A_PASSWORD=
SMOKE_USER_B_EMAIL=
SMOKE_USER_B_PASSWORD=
SMOKE_USER_A_PROFILE_ID=
SMOKE_USER_B_PROFILE_ID=
UNSTANDARD_SMOKE_EVIDENCE_OUT=

# --- Combined readiness (names only) ---
UNSTANDARD_INTEGRATION_EVIDENCE_PATH=
UNSTANDARD_SMOKE_EVIDENCE_PATH=
UNSTANDARD_READINESS_EVIDENCE_OUT=
UNSTANDARD_EXPECTED_PREVIEW_HOSTNAME=
UNSTANDARD_READINESS_EVIDENCE_PATH=

# --- Docker compose depth stack (dormant PoC, "local-ai-poc" Compose profile) ---
# `docker compose up` with no profile does NOT start tei/depth-service.
# Do not set these outside a dedicated Local AI PoC branch — see
# docs/LOCAL_AI_POC_STATUS.md. Absence of any value below keeps the service
# fully disabled even if it were started.
POSTGRES_DB=unstandard
POSTGRES_USER=unstandard
POSTGRES_PASSWORD=localdev
TEI_BASE_URL=http://tei:8080
# No default remote target. Qwen review stays disabled unless explicitly set.
QWEN_REVIEW_URL=
# Server-only opt-in + service-to-service auth token. Both are required
# in addition to an app_config local_ai_enabled=true before
# /internal/depth/evaluate will do any embedding/persistence work.
UNSTANDARD_LOCAL_AI_POC_ENABLED=
UNSTANDARD_DEPTH_SERVICE_TOKEN=
