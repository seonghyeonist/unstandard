# ========================================
# Unstandard .gitignore
# Next.js + Node.js + Supabase MVP
# ========================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Python (depth-service) ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# --- Build / Output ---
.next/
out/
build/
dist/

# --- Environment Variables (절대 커밋 금지) ---
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# --- Testing ---
coverage/
.nyc_output/

# --- Debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- Supabase ---
supabase/.temp/

# --- Docker ---
docker-compose.override.yml

# --- Misc ---
*.log
*.pid
*.seed
*.pid.lock
